# jack.kelliher.info — static file server
# Listens on localhost only; cloudflared connects to this.

:8780 {
    root * /var/lib/jack-site/www
    file_server

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    handle /health {
        respond "OK" 200
    }

    log {
        output stdout
        format console
    }
}
